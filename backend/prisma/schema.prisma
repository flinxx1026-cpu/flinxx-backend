generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("moderator")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Payment {
  id            Int      @id @default(autoincrement())
  userId        Int
  amount        Float
  status        String   @default("pending")
  transactionId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model Report {
  id             Int      @id @default(autoincrement())
  reportedUserId Int
  reason         String
  evidence       String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model Session {
  id        Int       @id @default(autoincrement())
  user1Id   Int
  user2Id   Int
  duration  Int
  quality   String    @default("high")
  createdAt DateTime  @default(now())
  endedAt   DateTime?
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  verified  Boolean  @default(false)
  banned    Boolean  @default(false)
  coins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model premium {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  status     String?   @default("inactive") @db.VarChar(50)
  start_date DateTime? @db.Timestamp(6)
  end_date   DateTime? @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_premium_user_id")
}

model reports {
  id                                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id                           String    @db.Uuid
  reported_user_id                      String    @db.Uuid
  reason                                String?   @db.VarChar(255)
  description                           String?
  status                                String?   @default("pending") @db.VarChar(50)
  created_at                            DateTime? @default(now()) @db.Timestamp(6)
  updated_at                            DateTime? @default(now()) @db.Timestamp(6)
  users_reports_reported_user_idTousers users     @relation("reports_reported_user_idTousers", fields: [reported_user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  users_reports_reporter_idTousers      users     @relation("reports_reporter_idTousers", fields: [reporter_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([created_at], map: "idx_reports_created_at")
  @@index([status], map: "idx_reports_status")
}

model sessions {
  id                             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user1_id                       String    @db.Uuid
  user2_id                       String    @db.Uuid
  started_at                     DateTime? @default(now()) @db.Timestamp(6)
  ended_at                       DateTime? @db.Timestamp(6)
  duration_seconds               Int?
  quality                        String?   @default("good") @db.VarChar(50)
  users_sessions_user1_idTousers users     @relation("sessions_user1_idTousers", fields: [user1_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  users_sessions_user2_idTousers users     @relation("sessions_user2_idTousers", fields: [user2_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([started_at], map: "idx_sessions_started_at")
  @@index([user1_id], map: "idx_sessions_user1")
  @@index([user2_id], map: "idx_sessions_user2")
}

model users {
  id                                                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                              String            @unique @db.VarChar(255)
  display_name                                       String?           @db.VarChar(255)
  photo_url                                          String?
  auth_provider                                      String?           @db.VarChar(50)
  provider_id                                        String?           @db.VarChar(255)
  google_id                                          String?           @unique
  birthday                                           DateTime?         @db.Timestamp(6)
  gender                                             String?
  age                                                Int?
  profileCompleted                                   Boolean?          @default(false)
  has_seen_premium_popup                             Boolean?          @default(false)
  created_at                                         DateTime?         @default(now()) @db.Timestamp(6)
  updated_at                                         DateTime?         @default(now()) @db.Timestamp(6)
  termsAccepted                                      Boolean?          @default(false)
  public_id                                          String?           @unique @db.VarChar(8)
  ban_reason                                         String?
  warning_count                                      Int?              @default(0)
  last_warning_at                                    DateTime?         @db.Timestamp(6)
  is_banned                                          Boolean?          @default(false)
  last_seen                                          DateTime?         @db.Timestamp(6)
  location                                           String?           @db.VarChar(255)
  profileImage                                       String?
  profileimage                                       String?
  has_blue_tick                                      Boolean?          @default(false)
  blue_tick_expires_at                               DateTime?         @db.Timestamp(6)
  has_match_boost                                    Boolean?          @default(false)
  match_boost_expires_at                             DateTime?         @db.Timestamp(6)
  has_profile_highlight                              Boolean?          @default(false)
  profile_highlight_expires_at                       DateTime?         @db.Timestamp(6)
  has_unlimited_skip                                 Boolean?          @default(false)
  unlimited_skip_expires_at                          DateTime?         @db.Timestamp(6)
  daily_skip_count                                   Int?              @default(0)
  last_skip_reset_date                               DateTime?         @db.Date
  accepted_guidelines                                Boolean?          @default(false)
  is_premium                                         Boolean?          @default(false)
  premium_type                                       String?           @db.VarChar(50)
  premium_expiry                                     DateTime?         @db.Timestamp(6)
  friend_requests_friend_requests_receiver_idTousers friend_requests[] @relation("friend_requests_receiver_idTousers")
  friend_requests_friend_requests_sender_idTousers   friend_requests[] @relation("friend_requests_sender_idTousers")
  matches_matches_matched_user_idTousers             matches[]         @relation("matches_matched_user_idTousers")
  matches_matches_user_idTousers                     matches[]         @relation("matches_user_idTousers")
  messages_messages_receiver_idTousers               messages[]        @relation("messages_receiver_idTousers")
  messages_messages_sender_idTousers                 messages[]        @relation("messages_sender_idTousers")
  payments                                           payments[]
  premium                                            premium[]
  reports_reports_reported_user_idTousers            reports[]         @relation("reports_reported_user_idTousers")
  reports_reports_reporter_idTousers                 reports[]         @relation("reports_reporter_idTousers")
  sessions_sessions_user1_idTousers                  sessions[]        @relation("sessions_user1_idTousers")
  sessions_sessions_user2_idTousers                  sessions[]        @relation("sessions_user2_idTousers")

  @@index([email], map: "idx_users_email")
  @@index([auth_provider, provider_id], map: "idx_users_provider")
  @@index([google_id], map: "idx_users_google_id")
  @@index([public_id], map: "idx_users_public_id")
  @@index([profileCompleted], map: "idx_users_profile_completed")
}

model friend_requests {
  id                                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                                String    @db.Uuid
  receiver_id                              String    @db.Uuid
  status                                   String?   @default("pending") @db.VarChar(20)
  created_at                               DateTime? @default(now()) @db.Timestamp(6)
  users_friend_requests_receiver_idTousers users     @relation("friend_requests_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_friend_requests_sender_idTousers   users     @relation("friend_requests_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sender_id, receiver_id])
  @@index([receiver_id], map: "idx_friend_requests_receiver")
  @@index([sender_id], map: "idx_friend_requests_sender")
}

model matches {
  id                                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                              String    @db.Uuid
  matched_user_id                      String    @db.Uuid
  matched_user_name                    String?   @db.VarChar(255)
  matched_user_country                 String?   @db.VarChar(255)
  duration_seconds                     Int?      @default(0)
  is_liked                             Boolean?  @default(false)
  created_at                           DateTime? @default(now()) @db.Timestamp(6)
  users_matches_matched_user_idTousers users     @relation("matches_matched_user_idTousers", fields: [matched_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_matches_user_idTousers         users     @relation("matches_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_matches_created_at")
  @@index([user_id], map: "idx_matches_user_id")
}

model messages {
  id                                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                         String    @db.Uuid
  receiver_id                       String    @db.Uuid
  message                           String
  message_type                      String?   @default("text") @db.VarChar(20)
  created_at                        DateTime? @default(now()) @db.Timestamp(6)
  is_read                           Boolean?  @default(false)
  is_deleted                        Boolean?  @default(false)
  reply_to_id                       String?   @db.Uuid
  users_messages_receiver_idTousers users     @relation("messages_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_messages_sender_idTousers   users     @relation("messages_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sender_id, receiver_id], map: "idx_messages_conversation")
  @@index([receiver_id], map: "idx_messages_receiver")
  @@index([sender_id], map: "idx_messages_sender")
}

model payments {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String    @db.Uuid
  plan_id                 String    @db.VarChar(50)
  plan_name               String    @db.VarChar(100)
  amount                  Int
  currency                String?   @default("INR") @db.VarChar(10)
  cashfree_order_id       String?   @db.VarChar(255)
  cashfree_payment_id     String?   @db.VarChar(255)
  cashfree_session_id     String?   @db.VarChar(255)
  status                  String?   @default("created") @db.VarChar(50)
  paid_at                 DateTime? @db.Timestamp(6)
  created_at              DateTime? @default(now()) @db.Timestamp(6)
  updated_at              DateTime? @default(now()) @db.Timestamp(6)
  users                   users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cashfree_order_id], map: "idx_payments_order_id")
  @@index([status], map: "idx_payments_status")
  @@index([user_id], map: "idx_payments_user_id")
}

model user_pair_skip_history {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user1_id       String    @db.Uuid
  user2_id       String    @db.Uuid
  skip_count     Int       @default(0)
  last_skip_time DateTime  @default(now()) @db.Timestamp(6)
  reset_at_time  DateTime  @default(now()) @db.Timestamp(6)
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @updatedAt @db.Timestamp(6)

  @@unique([user1_id, user2_id], map: "uk_user_pair_skip_history")
  @@index([reset_at_time], map: "idx_user_pair_skip_reset")
  @@index([user1_id], map: "idx_user_pair_skip_user1")
  @@index([user2_id], map: "idx_user_pair_skip_user2")
}
