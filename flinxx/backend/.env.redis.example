# Environment Configuration Template for Redis Matching System
# Copy this to .env.local and fill in your values

# ============================================================
# REDIS CONFIGURATION (NEW - REQUIRED FOR MATCHING SYSTEM)
# ============================================================

# Production Redis URL 
# Formats:
#   redis://localhost:6379                      (local)
#   redis://user:password@host:port            (with auth)
#   redis://redis.1234567.ng.0001.use1.cache.amazonaws.com:6379  (AWS ElastiCache)
#
REDIS_URL=redis://localhost:6379

# Enable in-memory fallback (for development without Redis)
# WARNING: Data will NOT persist on server restart
REDIS_FALLBACK=true

# ============================================================
# Node Environment (Existing)
# ============================================================
NODE_ENV=development
PORT=10000
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# ============================================================
# DATABASE (Existing)
# ============================================================
DATABASE_URL=postgresql://user:password@db:5432/flinxx

# ============================================================
# Firebase/Auth (Existing)
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:10000/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth

# ============================================================
# QUICK START GUIDE
# ============================================================

# Local Development (In-Memory):
# REDIS_FALLBACK=true
# NODE_ENV=development

# Local Development (With Local Redis):
# REDIS_URL=redis://localhost:6379
# docker run -d -p 6379:6379 redis:7-alpine

# Production:
# REDIS_URL=redis://username:password@production-redis.example.com:6379
# NODE_ENV=production
# REDIS_FALLBACK=false (or omit)

