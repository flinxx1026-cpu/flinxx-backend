# Backend Environment Variables (Copy this to .env)

# ===== SERVER =====
NODE_ENV=production
PORT=5000

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/flinxx
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=flinxx
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# ===== REDIS CACHE =====
# Connection string
REDIS_URL=redis://localhost:6379/0

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# For Docker:
# REDIS_URL=redis://redis:6379/0
# REDIS_HOST=redis

# ===== WebRTC - STUN/TURN SERVERS =====
# ✅ STUN: For normal NAT (auto-enabled always)
# ✅ TURN: For mobile/CGNAT networks (Airtel, Jio, etc)

# Enable TURN servers in production (recommended for mobile users)
TURN_SERVER=true

# Free public TURN server credentials
TURN_USERNAME=openrelayproject
TURN_PASSWORD=openrelayproject

# Self-hosted TURN server (optional - for production)
# Uncomment and set if using your own TURN server
# CUSTOM_TURN_SERVER=turn:your-turn-server.com:3478
# CUSTOM_TURN_USERNAME=your-username
# CUSTOM_TURN_PASSWORD=your-password

# Or for AWS, Azure, or other cloud providers
# CUSTOM_TURN_SERVER=turn:turn.your-provider.com:3478?transport=udp
# CUSTOM_TURN_USERNAME=your-username
# CUSTOM_TURN_PASSWORD=your-password

# ===== FIREBASE =====
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email@firebase.gserviceaccount.com

# ===== CASHFREE PAYMENT GATEWAY =====
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# ===== URLs FOR CASHFREE REDIRECT & WEBHOOK =====
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-backend-domain.com

# For development (using ngrok):
# FRONTEND_URL=https://xxxx-xx-xxx-xx-xxx.ngrok.io
# BACKEND_URL=https://xxxx-xx-xxx-xx-xxx.ngrok.io

# ===== JWT =====
JWT_SECRET=your-secret-key-change-this

# ===== EMAIL =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ===== LOGGING =====
LOG_LEVEL=debug
